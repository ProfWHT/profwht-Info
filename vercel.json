{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(sitemap.xml|BingSiteAuth.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/urls.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/urls.txt",
      "destination": "/urls.txt"
    },
    {
      "source": "/BingSiteAuth.xml",
      "destination": "/BingSiteAuth.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
